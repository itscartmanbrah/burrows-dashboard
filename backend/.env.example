# Server
PORT=4000
NODE_ENV=development

# JWT Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=12h

# Single admin login (for Phase 0 — simple credential-based auth)
ADMIN_USERNAME=admin
# Generate a bcrypt hash of your chosen password (see HOWTO for the helper command)
ADMIN_PASSWORD_HASH=

# PostgreSQL — burrows_jewellers (the existing data-sync database)
PGUSER=postgres
PGPASSWORD=
PGHOST=localhost
PGPORT=5432
PGDATABASE=burrows_jewellers

# PostgreSQL — pandora_reference (standalone DB, NOT related to burrows_jewellers —
# holds the Pandora build-to-level / discontinued master list imported from CSV)
PANDORA_PGUSER=postgres
PANDORA_PGPASSWORD=
PANDORA_PGHOST=localhost
PANDORA_PGPORT=5432
PANDORA_PGDATABASE=pandora_reference

# Allowed origin for CORS (the frontend dev server)
FRONTEND_ORIGIN=http://localhost:5173
